# ── Meta / Instagram ──────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
PAGE_ID=

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported values: openai | deepseek | openrouter
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ── MinIO (media storage) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=instagram-service
MINIO_SECURE=false

# ── Redis (optional caching) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Comma-separated posting hours (24-h), e.g. 9,12,18,20
POSTING_HOURS=9,12,18,20

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
